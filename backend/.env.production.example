PORT=5000
NODE_ENV=production

# Replace with your MongoDB Atlas URI or keep using the Docker mongo service
MONGO_URI=mongodb://mongo:27017/smg_ecommerce

# IMPORTANT: Change this to a strong random secret before deploying!
# Generate one with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS

JWT_EXPIRE=30d

# CORS — set to your actual domain
CORS_ORIGIN=https://yourdomain.com
